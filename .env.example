# Vobiz Python SDK — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.

# ─── Required: REST API Credentials ────────────────────────────────────────────
# Found in your Vobiz console: https://console.vobiz.ai
VOBIZ_AUTH_ID=MA_XXXXXXXXXX
VOBIZ_AUTH_TOKEN=your_auth_token_here

# ─── Required for making / receiving calls ─────────────────────────────────────
# Your Vobiz DID number (E.164 format, e.g. +911234567890)
FROM_PHONE_NUMBER=+91XXXXXXXXXX

# The number you want to call (E.164 format)
TO_PHONE_NUMBER=+91XXXXXXXXXX

# Public HTTPS URL that Vobiz will call when the outbound call is answered.
# Must be reachable from the internet — use ngrok for local development:
#   ngrok http 5001
# Then set this to: https://<your-ngrok-id>.ngrok-free.app/answer
# NOTE: macOS users — port 5000 is taken by AirPlay Receiver. Use 5001 or higher.
ANSWER_URL=https://<your-ngrok-id>.ngrok-free.app/answer
